    {
      "name": "CREATE New List Inside Board/To_Do",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "let randomName = 'ToDo_' + Math.floor(Math.random() * 10000)\r",
              "\r",
              "pm.collectionVariables.set('rndToDoList', randomName)"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "const jsonData = pm.response.json();\r",
              "const randomListName = pm.collectionVariables.get('rndToDoList');\r",
              "\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response has all the expected properties\", function () {\r",
              "    pm.expect(jsonData).to.have.all.keys('id', 'name', 'closed', 'color', 'idBoard', 'pos', 'type', 'datasource', 'limits')\r",
              "});\r",
              "\r",
              "pm.test(\"'closed' is false and of type boolean\", function () {\r",
              "    pm.expect(jsonData.closed).to.be.a('boolean');\r",
              "    pm.expect(jsonData.closed).to.be.false;\r",
              "});\r",
              "\r",
              "pm.test(\"'idBoard' matches expected board ID\", function () {\r",
              "    const expectedBoardID = pm.collectionVariables.get('boardID');\r",
              "    pm.expect(jsonData.idBoard).to.eql(expectedBoardID);\r",
              "});\r",
              "\r",
              "pm.test(`List name is ${randomListName}`, function () {\r",
              "    pm.expect(jsonData.name).to.eql(randomListName);\r",
              "});\r",
              "\r",
              "pm.collectionVariables.set('rndToDoListID', jsonData.id)"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
